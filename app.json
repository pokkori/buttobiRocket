{
  "expo": {
    "name": "rocket-fling",
    "slug": "rocket-fling",
    "version": "1.0.0",
    "description": "ぶっ飛びロケット - スリングショットでロケットを打ち上げ！惑星の重力を使って星に到達する物理パズルゲーム。100ステージ以上収録。3スターを目指して挑戦！キーワード: ロケットゲーム 物理パズル スリングショット 宇宙ゲーム パズルゲーム",
    "keywords": ["ぶっ飛びロケット", "物理パズル", "ロケット", "スリングショット", "宇宙ゲーム"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "rocket-fling",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E27"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pokkori.rocketfling"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0E27",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.pokkori.rocketfling"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "title": "ぶっ飛びロケット - 重力パズルで星3クリアを目指せ！",
      "description": "惑星の重力を操り、ロケットをゴールに導く物理パズルゲーム。100ステージ収録。ブラウザで無料プレイ！",
      "themeColor": "#0A0E27"
    },
    "plugins": [
      "expo-router",
      "expo-sharing"
    ]
  }
}
